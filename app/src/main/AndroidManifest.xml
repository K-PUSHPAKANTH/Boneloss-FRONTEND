            android:name=".CompleteProfileActivity"
            android:exported="false" />

        <!-- Student Dashboard Screen -->
        <activity
            android:name=".StudentDashboardActivity"
            android:exported="false" />

        <!-- Learning Modules Screen -->
        <activity
            android:name=".LearningModulesActivity"
            android:exported="false" />

        <!-- Clinician Dashboard Screen -->
        <activity
            android:name=".ClinicianDashboardActivity"
            android:exported="false" />

        <!-- Researcher Dashboard Screen -->
        <activity
            android:name=".ResearcherDashboardActivity"
            android:exported="false" />

        <!-- Analytics Dashboard Screen -->
        <activity
            android:name=".AnalyticsActivity"
            android:exported="false" />

        <!-- Patient History Screen -->
        <activity
            android:name=".PatientHistoryActivity"
            android:exported="false" />

        <!-- Settings Screen -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <!-- Edit Profile Screen -->
        <activity
            android:name=".NotificationsActivity"
            android:exported="false" />
        <activity
            android:name=".EditProfileActivity"
