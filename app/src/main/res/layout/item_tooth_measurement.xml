<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_measurement_item"
    android:orientation="vertical"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Circle Tooth ID -->
        <TextView
            android:id="@+id/tv_tooth_circle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_background_light_blue"
            android:gravity="center"
            android:text="11"
            android:textColor="@color/primary_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Details Column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/tv_tooth_circle"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tooth"
                android:textColor="@color/text_dark"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_tooth_id_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#11"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="-2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Root:"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_root_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12.5mm"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:layout_marginTop="-2dp" />
        </LinearLayout>

        <!-- Values Column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_loss_percent_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22%"
                android:textColor="#F59E0B"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_loss_mm_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="2.8mm"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/pb_loss_indicator"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:max="100"
        android:progress="22"
        android:progressDrawable="@drawable/progress_tooth_measure" />

</LinearLayout>
