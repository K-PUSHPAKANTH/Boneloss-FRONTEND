<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:orientation="vertical"
    tools:context=".DistributionAnalysisActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_dark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Percentage Bone Loss"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distribution analysis"
                android:textColor="@color/text_gray"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Overall Bone Loss Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_overall_bone_loss"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overall Bone Loss"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="32.5%"
                    android:textColor="#F97316"
                    android:textSize="44sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Moderate Periodontitis"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <ProgressBar
                        android:id="@+id/pb_overall"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_toStartOf="@id/tv_overall_percent"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        android:max="100"
                        android:progress="32"
                        android:progressDrawable="@drawable/progress_bone_loss" />

                    <TextView
                        android:id="@+id/tv_overall_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="32.5%"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Severity Distribution Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Severity Distribution"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_marginTop="24dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/circle_background"
                            app:tint="#F59E0B" />

                        <!-- Mocking the pie slice -->
                        <ImageView
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/bg_pie_slice_moderate" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6"
                            android:textColor="#F59E0B"
                            android:textSize="12sp"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentStart="true"
                            android:layout_marginStart="8dp"
                            android:layout_marginTop="20dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2"
                            android:textColor="#F97316"
                            android:textSize="12sp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="16dp"
                            android:layout_marginBottom="32dp" />
                    </RelativeLayout>

                    <!-- Legend -->
                    <GridLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:columnCount="2">

                        <LinearLayout android:gravity="center_vertical" android:layout_margin="4dp">
                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#10B981" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Healthy (0-15%)" android:textColor="#10B981" android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout android:gravity="center_vertical" android:layout_margin="4dp">
                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#F59E0B" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mild (15-33%)" android:textColor="#F59E0B" android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout android:gravity="center_vertical" android:layout_margin="4dp" android:layout_gravity="center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#F97316" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Moderate (33-50%)" android:textColor="#F97316" android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout android:gravity="center_vertical" android:layout_margin="4dp">
                            <View android:layout_width="12dp" android:layout_height="12dp" android:background="#EF4444" android:layout_marginEnd="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Severe (>50%)" android:textColor="#EF4444" android:textSize="13sp"/>
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Severity Breakdown Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Severity Breakdown"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp"/>

                    <!-- Mild Breakdown -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mild Loss (15-33%)" android:textColor="@color/text_gray" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_mild_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="6 teeth (75%)" android:textColor="#F59E0B" android:textStyle="bold" android:textSize="13sp"/>
                    </RelativeLayout>
                    <ProgressBar
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="24dp"
                        android:max="100"
                        android:progress="75"
                        android:progressDrawable="@drawable/progress_tooth_measure" />

                    <!-- Moderate Breakdown -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Moderate Loss (33-50%)" android:textColor="@color/text_gray" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_moderate_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="2 teeth (25%)" android:textColor="#F97316" android:textStyle="bold" android:textSize="13sp"/>
                    </RelativeLayout>
                    <ProgressBar
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="24dp"
                        android:max="100"
                        android:progress="25"
                        android:progressDrawable="@drawable/progress_bone_loss" />

                    <!-- Severe Breakdown -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Severe Loss (>50%)" android:textColor="@color/text_gray" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_severe_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0 teeth (0%)" android:textColor="#EF4444" android:textStyle="bold" android:textSize="13sp"/>
                    </RelativeLayout>
                    <ProgressBar
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/progress_bar_custom_red" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btn_severity_classification"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/button_primary"
                android:text="View Severity Classification"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
