<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_patient_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/iv_module_status"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/circle_green_light"
        android:padding="12dp"
        android:src="@drawable/ic_check_filled" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_module_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Understanding\nBone Loss Basics"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />

        <ProgressBar
            android:id="@+id/progressBar_module"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:max="100"
            android:progress="100"
            android:progressDrawable="@drawable/progress_bar_custom" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_review"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:background="@drawable/button_secondary_light"
        android:paddingHorizontal="16dp"
        android:text="Review"
        android:textAllCaps="false"
        android:textColor="@color/primary_blue"
        android:textSize="12sp"
        tools:ignore="TouchTargetSizeCheck" />
</LinearLayout>
